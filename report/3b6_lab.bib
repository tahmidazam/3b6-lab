@article{bernardMidinfraredOpticalCharacterization2018,
  title = {Mid-Infrared Optical Characterization of {{InGaAsP}}},
  author = {Bernard, Alice and Ravaro, Marco and Roland, Iännis and Gérard, Jean-Michel and Krakowski, Michel and Parillaud, Olivier and Gérard, Bruno and Favero, Ivan and Leo, Giuseppe},
  date = {2018-12-01},
  journaltitle = {JOSA B},
  shortjournal = {J. Opt. Soc. Am. B, JOSAB},
  volume = {35},
  number = {12},
  pages = {C25-C28},
  publisher = {Optica Publishing Group},
  issn = {1520-8540},
  doi = {10.1364/JOSAB.35.000C25},
  url = {https://opg.optica.org/josab/abstract.cfm?uri=josab-35-12-C25},
  urldate = {2026-03-19},
  abstract = {We present a measurement of the refractive index of In1\&\#x2212;xGaxAsyP1\&\#x2212;y lattice-matched to InP outside of the range available in the literature. We have accurately determined the refractive index of In1\&\#x2212;xGaxAsyP1\&\#x2212;y lattice-matched to InP as a function of wavelength (\&\#x03BB;=1.55, 2.12, and 3\&\#x00A0;\&\#x03BC;m) and arsenic molar fraction (y=0.55, 0.7, and 0.72). Data is interpolated with a theoretical model and compared to the literature whenever possible. Agreement with currently available data is good. Uncertainties are estimated, the largest one being related to the sample composition. We also measure propagation losses dominated by scattering (0.15\&\#x2013;1.2\&\#x2009;\&\#x2009;cm\&\#x2212;1) in ridge waveguides, for the same range of compositions at wavelengths of 1.55\&\#x00A0;\&\#x03BC;m and 2.12\&\#x00A0;\&\#x03BC;m.},
  langid = {english},
  keywords = {Diode lasers,Electron beam lithography,Laser beam combining,Physical vapor deposition,Refractive index,Tunable diode lasers}
}

@article{brobergRefractiveIndexIn1xGaxAsyP1y1984,
  title = {Refractive Index of {{In1}}-{{xGaxAsyP1}}-y Layers and {{InP}} in the Transparent Wavelength Region},
  author = {Broberg, B. and Lindgren, S.},
  date = {1984-05-01},
  journaltitle = {Journal of Applied Physics},
  shortjournal = {J. Appl. Phys.},
  volume = {55},
  number = {9},
  pages = {3376--3381},
  issn = {0021-8979},
  doi = {10.1063/1.333377},
  url = {https://doi.org/10.1063/1.333377},
  urldate = {2026-03-19},
  abstract = {We have measured the refractive index of InP and of liquid‐phase‐epitaxy–grown InGaAsP layers on InP in the transparent wavelength region using a Brewster‐angle method. The dependence of the refractive index on material composition and light wavelength has been investigated for near‐lattice‐matched samples and compared with theoretical models. We show that both an interband transition model and a single effective oscillator model can be used to calculate the refractive index if the parameters used in the calculations are chosen properly. We have also studied the variation with lattice mismatch by varying the growth temperature. We found that a lattice mismatch variation of 10-3 corresponds to a change in the refractive index of approximately 0.02 for λg=1.20 μm layer band gap at λ=1.30 μm wavelength. Finally, we have measured the refractive index of doped InP substrates and found refractive index reductions, due to doping, of up to 0.05.},
  file = {/Users/tahmidazam/Zotero/storage/52UDPUZ7/Broberg and Lindgren - 1984 - Refractive index of In1-xGaxAsyP1-y layers and InP in the transparent wavelength region.pdf;/Users/tahmidazam/Zotero/storage/9LET59Y4/1.html}
}

